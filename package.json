{
	"name": "dump-verifier",
	"version": "2.0.2",
	"description": "A tool to verify game dumps using the redump.org and no-intro.org databases.",
	"license": "Apache-2.0",
	"author": "Óscar Maganto Torres",
	"main": "dist/js/main.cjs",
	"type": "module",
	"scripts": {
		"start": "electron-forge start",
		"make": "node --no-warnings --experimental-strip-types esbuild.config.ts build && electron-forge make --arch=x64 && electron-forge make --arch=arm64",
		"watch": "node --no-warnings --experimental-strip-types esbuild.config.ts watch",
		"build": "node --no-warnings --experimental-strip-types esbuild.config.ts build",
		"release": "electron-forge make"
	},
	"keywords": [],
	"dependencies": {
		"@eslint/js": "^9.39.4",
		"boolean": "^3.2.0",
		"countries-list": "^3.3.0",
		"electron-squirrel-startup": "^1.0.1",
		"esbuild-sass-plugin": "^3.6.0",
		"eslint": "^9.39.4",
		"eslint-plugin-jsdoc": "^61.7.1",
		"fastest-levenshtein": "^1.0.16",
		"glob": "^13.0.6",
		"jquery": "^3.7.1",
		"js-confetti": "^0.12.0",
		"jszip": "^3.10.1",
		"keytar": "^7.9.0",
		"lefthook": "^2.1.4",
		"prettier": "^3.8.1",
		"tar": "^7.5.13",
		"tippy.js": "^6.3.7",
		"tom-select": "^2.4.3",
		"typescript-eslint": "^8.58.0"
	},
	"devDependencies": {
		"@electron-forge/cli": "^7.8.2",
		"@electron-forge/maker-deb": "^7.8.2",
		"@electron-forge/maker-rpm": "^7.11.1",
		"@electron-forge/maker-squirrel": "^7.8.2",
		"@electron-forge/maker-zip": "^7.8.2",
		"@electron-forge/plugin-auto-unpack-natives": "^7.8.2",
		"@electron-forge/plugin-fuses": "^7.8.2",
		"@electron/fuses": "^1.8.0",
		"@types/jquery": "^3.5.32",
		"@types/tippy.js": "^6.3.0",
		"electron": "^41.1.1",
		"esbuild": "^0.27.2"
	}
}
